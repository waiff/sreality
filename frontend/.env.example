# Copy to .env (or .env.local) for local dev. Railway reads the same
# variable names from its service Variables panel for production.

# Public Supabase project URL. Looks like https://<ref>.supabase.co.
VITE_SUPABASE_URL=

# Supabase publishable / anon key. Safe to ship to the browser; reads are
# fenced by the listings_public / listing_snapshots_public / etc. views
# created in migration 008. Never put the service-role key here.
VITE_SUPABASE_ANON_KEY=

# Railway FastAPI service base URL — e.g. https://sreality-api.up.railway.app.
# Frontend hits this for the /estimations endpoints (U2). No trailing slash.
VITE_API_BASE_URL=

# Bearer token for the FastAPI service (matches API_TOKEN on the Railway
# service). NOT a secret in any meaningful sense — it ships in the JS bundle
# and is extractable by anyone who opens devtools. Same security category as
# the password gate; the real protection is the password gate plus the URL
# not being shared. See frontend/README.md.
VITE_API_TOKEN=

# Public base URL of the Cloudflare R2 bucket that holds listing images.
# Listing photos are served as `${VITE_R2_PUBLIC_BASE}/${storage_path}`.
# When unset, the UI falls back to the original sreality CDN URLs, which
# expire — so leaving this blank makes images render as "Unavailable".
# Either an r2.dev dev URL (https://pub-<hash>.r2.dev) or a custom domain
# bound to the bucket. No trailing slash needed. Public read-only; safe in
# the browser bundle.
VITE_R2_PUBLIC_BASE=
