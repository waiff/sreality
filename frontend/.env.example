# Copy to .env (or .env.local) for local dev. Cloudflare Pages reads
# the same variable names from its dashboard env-var settings.

# Public Supabase project URL. Looks like https://<ref>.supabase.co.
VITE_SUPABASE_URL=

# Supabase publishable anon key. Safe to ship to the browser; reads are
# gated by the listings_public / listing_snapshots_public / etc. views
# created in migration 008. Never put the service-role key here.
VITE_SUPABASE_ANON_KEY=

# SHA-256 hex digest of the unlock password. Generate one with either:
#   node -e 'crypto.subtle.digest("SHA-256", new TextEncoder().encode("YOUR_PASSWORD")).then(b => console.log(Buffer.from(b).toString("hex")))'
#   echo -n "YOUR_PASSWORD" | shasum -a 256
# The password gate is a soft barrier ("don't share the URL widely"),
# not real auth. Real protection is the read-only views + this is data
# already published on sreality.cz.
VITE_PASSWORD_HASH=
