{
	# Railway terminates TLS at its edge; the app speaks plain HTTP.
	auto_https off
	admin off
}

:{$PORT:80} {
	root * /srv
	encode gzip zstd

	# Liveness endpoint Railway hits per railway.json healthcheckPath.
	@healthz path /healthz
	handle @healthz {
		respond "ok" 200
	}

	# Vite emits hashed bundles into /assets/, so they are immutable.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Everything else (index.html, manifest, favicons) revalidates so a
	# redeploy is visible immediately.
	@notassets not path /assets/*
	header @notassets Cache-Control "public, max-age=0, must-revalidate"

	# Baseline security headers.
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header X-Frame-Options "DENY"
	header -Server

	# SPA fallback so client-side routes (/listing/:id, /region, etc.)
	# resolve to the bundled index.
	try_files {path} /index.html
	file_server
}
