{
	# Railway terminates TLS at its edge; the app speaks plain HTTP.
	auto_https off
	admin off
}

:{$PORT:80} {
	root * /srv
	encode gzip zstd

	# Liveness endpoint Railway hits per railway.json healthcheckPath.
	# Exclusive handle block — no fall-through to try_files/file_server.
	handle /healthz {
		respond "ok" 200
	}

	# Hashed bundles in /assets/ are immutable; long-cache them and
	# serve directly without SPA fallback.
	handle_path /assets/* {
		root * /srv/assets
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Everything else: SPA fallback to /index.html, no aggressive cache.
	handle {
		header Cache-Control "public, max-age=0, must-revalidate"
		header X-Content-Type-Options "nosniff"
		header Referrer-Policy "strict-origin-when-cross-origin"
		header X-Frame-Options "DENY"
		header -Server

		try_files {path} /index.html
		file_server
	}
}
