# Copy to .env for local development. NEVER commit the real .env file.
# In production these are GitHub Actions secrets, not a file.

# Supabase project URL, e.g. https://erlvtprrmrylhznfyaih.supabase.co
SUPABASE_URL=

# Supabase service-role secret. New 2025 format starting with sb_secret_...
# This is NOT a JWT. Kept for forward compatibility; the v1 scraper does
# not need it because we connect to Postgres directly via SUPABASE_DB_URL.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string from Supabase project.
# Project Settings -> Database -> Connection string -> Transaction pooler.
# Format: postgresql://postgres.<ref>:<password>@<host>:6543/postgres
SUPABASE_DB_URL=

# Cloudflare R2 credentials for image storage. If any of these are
# missing the image-download phase becomes a no-op (the scraper still
# records image URLs in the images table; it just doesn't download).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional: override scrape scope. Defaults match v1 spec.
# SREALITY_CATEGORY_MAIN=1     # 1=byt, 2=dum
# SREALITY_CATEGORY_TYPE=2     # 1=prodej, 2=pronajem
# SREALITY_COUNTRY_ID=10001    # 10001 = Czech Republic

# Bearer token for the FastAPI service. If unset (local development),
# every endpoint is open. If set (production on Railway), every endpoint
# EXCEPT /health requires Authorization: Bearer <this-value>.
API_TOKEN=

# Anthropic API key. Required by the FastAPI service for LLM-driven
# parsing of non-sreality listing URLs (bezrealitky / idnes-reality /
# remax / unsupported sources). Backend-only; never expose to the
# browser. Every call is logged to the llm_calls table with token
# counts and USD cost.
ANTHROPIC_API_KEY=

# Mapy.cz REST API key. Used by the URL parser to geocode locality
# strings extracted from non-sreality listings (those sources rarely
# include coordinates on the page). Backend-only.
MAPY_CZ_API_KEY=
