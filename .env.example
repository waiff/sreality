# Copy to .env for local development. NEVER commit the real .env file.
# In production these are GitHub Actions secrets, not a file.

# Supabase project URL, e.g. https://erlvtprrmrylhznfyaih.supabase.co
SUPABASE_URL=

# Supabase service-role secret. New 2025 format starting with sb_secret_...
# This is NOT a JWT. Kept for forward compatibility; the v1 scraper does
# not need it because we connect to Postgres directly via SUPABASE_DB_URL.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string from Supabase project.
# Project Settings -> Database -> Connection string -> Transaction pooler.
# Format: postgresql://postgres.<ref>:<password>@<host>:6543/postgres
SUPABASE_DB_URL=

# Optional: override scrape scope. Defaults match v1 spec.
# SREALITY_CATEGORY_MAIN=1     # 1=byt, 2=dum
# SREALITY_CATEGORY_TYPE=2     # 1=prodej, 2=pronajem
# SREALITY_COUNTRY_ID=10001    # 10001 = Czech Republic
