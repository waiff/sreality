{
  "manifest_version": 3,
  "name": "Limen Reality — výnos & pipeline",
  "version": "0.8.0",
  "description": "Overlays our MF reference rent + Výnos MF gross yield on listing detail and search pages across every portal we scrape, deep-links to the app, and bookmarks a property into the deal pipeline.",
  "permissions": ["storage", "identity", "alarms"],
  "host_permissions": [],
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.sreality.cz/*",
        "https://sreality.cz/*",
        "https://reality.bazos.cz/*",
        "https://www.bezrealitky.cz/*",
        "https://bezrealitky.cz/*",
        "https://bezrealitky.com/*",
        "https://reality.idnes.cz/*",
        "https://nemovitosti.maxima.cz/*",
        "https://www.remax-czech.cz/*",
        "https://remax-czech.cz/*",
        "https://www.mmreality.cz/*",
        "https://mmreality.cz/*",
        "https://www.ceskereality.cz/*",
        "https://ceskereality.cz/*",
        "https://realitymix.cz/*",
        "https://www.realitymix.cz/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
