# Copy to .env (or .env.local) before running `npm run build`. The
# values are inlined into the extension bundle at build time — same
# pattern as the frontend SPA. The bundle that ships in dist/ is
# therefore deployment-specific; do not check it into source control.

# Railway FastAPI service base URL — e.g. https://sreality-api.up.railway.app
# No trailing slash.
VITE_API_BASE_URL=

# Bearer token for the FastAPI service (matches API_TOKEN on the
# Railway service, same value used by VITE_API_TOKEN in the SPA).
#
# IMPORTANT — distribution policy:
#   The token ships inside the .crx (or unpacked extension folder).
#   Anyone with that file can extract it. Distribute only to operators
#   you trust; do NOT upload this build to the public Chrome Web Store.
#   See chrome-extension/README.md for the rationale and alternatives.
VITE_API_TOKEN=
