# Copy to .env (or .env.local) before running `npm run build`. The
# values are inlined into the extension bundle at build time — same
# pattern as the frontend SPA. The bundle that ships in dist/ is
# therefore deployment-specific; do not check it into source control.

# Railway FastAPI service base URL — e.g. https://sreality-api.up.railway.app
# No trailing slash.
VITE_API_BASE_URL=

# Supabase project URL + anon (publishable) key — the SAME values as the
# SPA's VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY (frontend/.env.example).
# The extension runs its OWN Supabase session (Wave 1): a hand-rolled PKCE
# sign-in via chrome.identity.launchWebAuthFlow, never the SPA's session or
# refresh token. The anon key is safe to ship — it's the public client key,
# not a secret (same posture as the SPA bundling it).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# SPA (browser app) base URL — e.g. https://sreality.up.railway.app — used for
# the "Otevřít v aplikaci" link to a listing's page (/listing/{sreality_id}).
# No trailing slash. OPTIONAL: leave empty to hide the link.
VITE_APP_BASE_URL=
